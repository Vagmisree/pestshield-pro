# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pestshield?schema=public

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── AWS S3 ──────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=pestshield-uploads
AWS_REGION=ap-south-1

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Google Maps ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── WhatsApp (Interakt / Gupshup) ───────────────────────
INTERAKT_API_KEY=
WHATSAPP_FROM_NUMBER=

# ─── MSG91 (SMS OTP) ─────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID_OTP=
MSG91_TEMPLATE_ID_BOOKING=

# ─── SendGrid (Email) ────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@pestshieldpro.in

# ─── Firebase (Push Notifications) ───────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Shiprocket (DIY Shop Delivery) ─────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
